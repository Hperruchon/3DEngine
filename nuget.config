<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Local folder feed for the native Manifold payload (interim bootstrap, TASK-0012 §6).
    The `nuget/` folder holds Engine.Geometry.Manifold.Native.<ver>.nupkg produced by the
    build-manifold-native workflow. nuget.org still applies for all other packages
    (sources merge across the config hierarchy unless <clear/> is used).
  -->
  <packageSources>
    <add key="manifold-local" value="nuget" />
  </packageSources>
</configuration>
